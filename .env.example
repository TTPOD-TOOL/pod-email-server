# POD Email Server — Environment Variables
# Copy file này thành .env và điền thông tin thật

# Bảo mật API — nhân viên phải gửi key này khi gọi server
API_SECRET=your-secret-key-here

# Domain được phép gọi server (Vercel URL của bạn)
ALLOWED_ORIGIN=https://demo-git-main-trinhdx-s-projects.vercel.app

# Port (Railway tự set, không cần đổi)
PORT=3000

# Cấu hình các store email — format JSON
# Mỗi store cần: id, host, port, email, password
STORES_CONFIG=[
  {
    "id": "store-id-trong-supabase-1",
    "name": "STORE1",
    "imap_host": "mail.privateemail.com",
    "imap_port": 993,
    "smtp_host": "mail.privateemail.com",
    "smtp_port": 465,
    "email": "support@store1.com",
    "password": "mat-khau-email-1"
  },
  {
    "id": "store-id-trong-supabase-2",
    "name": "STORE2",
    "imap_host": "mail.privateemail.com",
    "imap_port": 993,
    "smtp_host": "mail.privateemail.com",
    "smtp_port": 465,
    "email": "support@store2.com",
    "password": "mat-khau-email-2"
  }
]
